###############################################
# StayFinder Python Backend — Environment
###############################################

# ── Database ──────────────────────────────────
# SQLite (default, zero config)
DATABASE_PATH=stayfinder.db

# PostgreSQL (production) — use psycopg2 adapter
# DATABASE_URL=postgresql://user:password@localhost:5432/stayfinder

# ── Server ────────────────────────────────────
PORT=4000
FLASK_ENV=development        # development | production
FRONTEND_URL=http://localhost:3000

# ── Auth / JWT ────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
REFRESH_TOKEN_SECRET=another_long_random_string_for_refresh
JWT_EXPIRES_MINUTES=15
REFRESH_EXPIRES_DAYS=7

# ── File Uploads ──────────────────────────────
UPLOAD_FOLDER=uploads
MAX_CONTENT_MB=5
